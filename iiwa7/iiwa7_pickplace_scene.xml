<mujoco model="iiwa7_pickplace_scene">
  <!-- Pick-and-place scene:
       - two static "target pads" at the pickup and place locations
       - one mocap body "cube" that starts at pickup and gets attached to the
         EE during the grab phase (Python code sets data.mocap_pos each step)
  -->

  <include file="iiwa7_tuned.xml"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="135" elevation="-25" offwidth="720" offheight="540"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0.2"/>
    <material name="pad_pickup"  rgba="0.2 0.7 1.0 0.45"/>
    <material name="pad_place"   rgba="1.0 0.7 0.2 0.45"/>
    <material name="cube_mat"    rgba="0.95 0.25 0.15 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.8" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Pickup pad at (0.5, -0.2, 0.35) -->
    <geom name="pad_pickup" type="box" size="0.06 0.06 0.005"
          pos="0.5 -0.2 0.35" material="pad_pickup" contype="0" conaffinity="0"/>
    <!-- Place pad at (0.5, +0.2, 0.35) -->
    <geom name="pad_place" type="box" size="0.06 0.06 0.005"
          pos="0.5  0.2 0.35" material="pad_place" contype="0" conaffinity="0"/>

    <!-- Mocap "cube": starts on the pickup pad, moved by Python during grab phase -->
    <body name="cube" mocap="true" pos="0.5 -0.2 0.385">
      <geom name="cube_geom" type="box" size="0.03 0.03 0.03"
            material="cube_mat" contype="0" conaffinity="0"/>
    </body>
  </worldbody>
</mujoco>
