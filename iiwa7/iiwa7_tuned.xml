<mujoco model="iiwa7_tuned">
  <!--
    iiwa7 MJCF with geometry-split visual meshes.

    Visual:    iiwa7 STL split by KD-tree nearest-neighbor classification
               against mujoco_menagerie iiwa14's split OBJ reference.
               link_2/4/6 each become orange + grey sub-meshes; others stay
               single-piece. Material colors follow Drake PR #36 (grey 0.2,
               orange 1.0/0.15/0).
    Collision: original iiwa_stack iiwa7 STL files (unchanged — drive physics).
    Kinematics/dynamics: body_pos, inertias, joint ranges, masses all iiwa7
               originals. Controller tuning kept identical.

    Tuning (menagerie-derived):
      - general actuator gaintype=fixed biastype=affine,
        gainprm=2000 biasprm="0 -2000 -200" (PD kp=2000 kd=200)
      - per-joint forcerange matching iiwa7 datasheet torques
      - armature 0.1 for numerical stability under stiff PD
      - 7 contact excludes between non-adjacent bodies
      - joint damping 0.5 from URDF (kept for passive-sim stability)
  -->

  <compiler angle="radian" meshdir="../meshes" autolimits="true"/>

  <option integrator="implicitfast" timestep="0.002"/>

  <default>
    <default class="iiwa">
      <joint axis="0 0 1" damping="0.5" armature="0.1"/>
      <general gaintype="fixed" biastype="affine" gainprm="2000" biasprm="0 -2000 -200"/>
      <default class="joint1">
        <joint range="-2.96706 2.96706"/>
        <general ctrlrange="-2.96706 2.96706" forcerange="-176 176"/>
      </default>
      <default class="joint2">
        <joint range="-2.09440 2.09440"/>
        <general ctrlrange="-2.09440 2.09440" forcerange="-176 176"/>
      </default>
      <default class="joint3_mid">
        <joint range="-2.96706 2.96706"/>
        <general ctrlrange="-2.96706 2.96706" forcerange="-110 110"/>
      </default>
      <default class="joint4_mid">
        <joint range="-2.09440 2.09440"/>
        <general ctrlrange="-2.09440 2.09440" forcerange="-110 110"/>
      </default>
      <default class="joint5_mid">
        <joint range="-2.96706 2.96706"/>
        <general ctrlrange="-2.96706 2.96706" forcerange="-110 110"/>
      </default>
      <default class="joint6_distal">
        <joint range="-2.09440 2.09440"/>
        <general ctrlrange="-2.09440 2.09440" forcerange="-40 40"/>
      </default>
      <default class="joint7_distal">
        <joint range="-3.05433 3.05433"/>
        <general ctrlrange="-3.05433 3.05433" forcerange="-40 40"/>
      </default>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2" material="iiwa_grey"/>
      </default>
      <default class="collision">
        <geom type="mesh" group="3"/>
      </default>
    </default>
  </default>

  <asset>
    <!-- Materials (Drake PR #36 official iiwa7 scheme) -->
    <material name="iiwa_grey"   rgba="0.2 0.2 0.2 1" specular="0.5" shininess="0.25"/>
    <material name="iiwa_orange" rgba="1.0 0.15 0 1" specular="0.5" shininess="0.25"/>

    <!-- Visual meshes: iiwa7 STL split by mesh-surface classification -->
    <mesh name="link_0_vis"        file="iiwa7_split/link_0.obj"/>
    <mesh name="link_1_vis"        file="iiwa7_split/link_1.obj"/>
    <mesh name="link_2_orange_vis" file="iiwa7_split/link_2_orange.obj"/>
    <mesh name="link_2_grey_vis"   file="iiwa7_split/link_2_grey.obj"/>
    <mesh name="link_3_vis"        file="iiwa7_split/link_3.obj"/>
    <mesh name="link_4_orange_vis" file="iiwa7_split/link_4_orange.obj"/>
    <mesh name="link_4_grey_vis"   file="iiwa7_split/link_4_grey.obj"/>
    <mesh name="link_5_vis"        file="iiwa7_split/link_5.obj"/>
    <mesh name="link_6_orange_vis" file="iiwa7_split/link_6_orange.obj"/>
    <mesh name="link_6_grey_vis"   file="iiwa7_split/link_6_grey.obj"/>
    <mesh name="link_7_vis"        file="iiwa7_split/link_7.obj"/>

    <!-- Collision meshes: original iiwa7 STL (unscaled — drives physics) -->
    <mesh name="link_0_col" file="iiwa7/collision/link_0.stl"/>
    <mesh name="link_1_col" file="iiwa7/collision/link_1.stl"/>
    <mesh name="link_2_col" file="iiwa7/collision/link_2.stl"/>
    <mesh name="link_3_col" file="iiwa7/collision/link_3.stl"/>
    <mesh name="link_4_col" file="iiwa7/collision/link_4.stl"/>
    <mesh name="link_5_col" file="iiwa7/collision/link_5.stl"/>
    <mesh name="link_6_col" file="iiwa7/collision/link_6.stl"/>
    <mesh name="link_7_col" file="iiwa7/collision/link_7.stl"/>
  </asset>

  <worldbody>
    <body name="iiwa_link_0" childclass="iiwa">
      <geom class="visual" mesh="link_0_vis"/>
      <geom class="collision" mesh="link_0_col"/>

      <body name="iiwa_link_1" pos="0 0 0.15">
        <inertial pos="0 -0.03 0.12" quat="0.428904 0.562175 -0.562175 0.428904"
                  mass="3.4525" diaginertia="0.0218946 0.02183 0.00663837"/>
        <joint name="iiwa_joint_1" class="joint1"/>
        <geom class="visual" pos="0 0 0.0075" mesh="link_1_vis"/>
        <geom class="collision" mesh="link_1_col"/>

        <body name="iiwa_link_2" pos="0 0 0.19" quat="0 0 0.707107 0.707107">
          <inertial pos="0.0003 0.059 0.042" quat="0.701371 0.0898824 0.0898824 0.701371"
                    mass="3.4821" diaginertia="0.02179 0.0217049 0.00684512"/>
          <joint name="iiwa_joint_2" class="joint2"/>
          <geom class="visual" material="iiwa_orange" mesh="link_2_orange_vis"/>
          <geom class="visual" mesh="link_2_grey_vis"/>
          <geom class="collision" mesh="link_2_col"/>

          <body name="iiwa_link_3" pos="0 0.21 0" quat="0 0 0.707107 0.707107">
            <inertial pos="0 0.03 0.13" quat="0.56292 0.427927 -0.427927 0.56292"
                      mass="4.05623" diaginertia="0.0321488 0.03204 0.00799117"/>
            <joint name="iiwa_joint_3" class="joint3_mid"/>
            <geom class="visual" pos="0 0 -0.026" mesh="link_3_vis"/>
            <geom class="collision" mesh="link_3_col"/>

            <body name="iiwa_link_4" pos="0 0 0.19" quat="0.707107 0.707107 0 0">
              <inertial pos="0 0.067 0.034" quat="0.991887 -0.127124 0 0"
                        mass="3.4822" diaginertia="0.02178 0.0216947 0.00684029"/>
              <joint name="iiwa_joint_4" class="joint4_mid"/>
              <geom class="visual" material="iiwa_orange" mesh="link_4_orange_vis"/>
              <geom class="visual" mesh="link_4_grey_vis"/>
              <geom class="collision" mesh="link_4_col"/>

              <body name="iiwa_link_5" pos="0 0.21 0" quat="0 0 0.707107 0.707107">
                <inertial pos="0.0001 0.021 0.076" quat="0.365352 0.605407 -0.605407 0.365352"
                          mass="2.1633" diaginertia="0.0131987 0.01287 0.0036293"/>
                <joint name="iiwa_joint_5" class="joint5_mid"/>
                <geom class="visual" pos="0 0 -0.026" mesh="link_5_vis"/>
                <geom class="collision" mesh="link_5_col"/>

                <body name="iiwa_link_6" pos="0 0.0607 0.19" quat="0.707107 0.707107 0 0">
                  <inertial pos="0 0.0006 0.0004" quat="0.996112 0.088097 0 0"
                            mass="2.3466" diaginertia="0.006509 0.00631585 0.00447015"/>
                  <joint name="iiwa_joint_6" class="joint6_distal"/>
                  <geom class="visual" material="iiwa_orange" mesh="link_6_orange_vis"/>
                  <geom class="visual" mesh="link_6_grey_vis"/>
                  <geom class="collision" mesh="link_6_col"/>

                  <body name="iiwa_link_7" pos="0 0.081 0.0607" quat="0 0 0.707107 0.707107">
                    <inertial pos="0 0 0.02" quat="0.923068 0 0 0.384636"
                              mass="3.129" diaginertia="0.0152362 0.0140538 0.002872"/>
                    <joint name="iiwa_joint_7" class="joint7_distal"/>
                    <geom class="visual" pos="0 0 -0.0005" mesh="link_7_vis"/>
                    <geom class="collision" mesh="link_7_col"/>
                    <site name="attachment_site" pos="0 0 0.05" size="0.005" rgba="1 0 0 1" group="4"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <contact>
    <exclude body1="iiwa_link_0" body2="iiwa_link_1"/>
    <exclude body1="iiwa_link_0" body2="iiwa_link_2"/>
    <exclude body1="iiwa_link_0" body2="iiwa_link_3"/>
    <exclude body1="iiwa_link_1" body2="iiwa_link_3"/>
    <exclude body1="iiwa_link_3" body2="iiwa_link_5"/>
    <exclude body1="iiwa_link_4" body2="iiwa_link_7"/>
    <exclude body1="iiwa_link_5" body2="iiwa_link_7"/>
  </contact>

  <actuator>
    <general name="actuator1" joint="iiwa_joint_1" class="joint1"/>
    <general name="actuator2" joint="iiwa_joint_2" class="joint2"/>
    <general name="actuator3" joint="iiwa_joint_3" class="joint3_mid"/>
    <general name="actuator4" joint="iiwa_joint_4" class="joint4_mid"/>
    <general name="actuator5" joint="iiwa_joint_5" class="joint5_mid"/>
    <general name="actuator6" joint="iiwa_joint_6" class="joint6_distal"/>
    <general name="actuator7" joint="iiwa_joint_7" class="joint7_distal"/>
  </actuator>

  <keyframe>
    <key name="home"  qpos="0 0 0 0 0 0 0"            ctrl="0 0 0 0 0 0 0"/>
    <key name="ready" qpos="0 0.5 0 -1.2 0 0.8 0"    ctrl="0 0.5 0 -1.2 0 0.8 0"/>
  </keyframe>
</mujoco>
