<mujoco model="iiwa7_tuned">
  <!--
    iiwa7 MJCF, tuned after cross-reference with mujoco_menagerie's iiwa14:
    https://github.com/google-deepmind/mujoco_menagerie/blob/main/kuka_iiwa_14/iiwa14.xml

    Diffs from the auto-generated iiwa7.xml:
      1. <default> class hierarchy (iiwa / joint1 / joint2 / joint3) — dedupes
         joint ranges and actuator ctrlrange per menagerie convention.
      2. Actuator switched from `position` (pure P, no velocity term) to
         `general` with gaintype=fixed, biastype=affine — gives full PD control
         via gainprm/biasprm. kp=2000 kd=200 uniform across joints
         (menagerie iiwa14 uses exactly these values; stable for any
         iiwa-scale 7-DOF arm).
      3. <forcerange> added per joint, matching iiwa7 datasheet torque limits
         (J1/2: 176 Nm, J3/4/5: 110 Nm, J6/7: 40 Nm). iiwa7 torque ceilings
         are lower than iiwa14's (which peaks at 320 Nm on J1/J2).
      4. <armature> added (0.1) to all joints — reflects harmonic-drive rotor
         inertia through the gearbox; improves numerical stability at large
         dt/kp combinations. menagerie omits this but we have higher kp/I on
         distal joints so benefit is visible.
      5. <contact><exclude> clauses prevent false self-contacts between
         non-adjacent bodies (base-link2, base-link3, link1-link3, link3-link5,
         link4-link7, link5-link7). Copied verbatim from menagerie topology.
      6. attachment_site added at (0 0 0.05) on link7 — standard menagerie
         convention for tool mounting / IK target.
      7. Joint damping kept at 0.5 from URDF (different from menagerie, which
         uses 0). Rationale: 0.5 << actuator kd=200, so actuator-in-loop
         behavior is unchanged; but when the actuator is disabled the model
         still settles passively instead of free-fall oscillating.

    Inertias are NOT copied from menagerie — iiwa14 link masses (5.76 / 6.35
    / 3.5 kg) differ from iiwa7 link masses (3.45 / 3.48 / 4.06 kg). The
    URDF-sourced values in iiwa7.xml are the correct iiwa7 values.
  -->

  <compiler angle="radian" meshdir="../meshes/iiwa7" autolimits="true"/>

  <option integrator="implicitfast" timestep="0.002"/>

  <default>
    <default class="iiwa">
      <joint axis="0 0 1" damping="0.5" armature="0.1"/>
      <general gaintype="fixed" biastype="affine" gainprm="2000" biasprm="0 -2000 -200"/>
      <default class="joint1">
        <joint range="-2.96706 2.96706"/>
        <general ctrlrange="-2.96706 2.96706" forcerange="-176 176"/>
      </default>
      <default class="joint2">
        <joint range="-2.09440 2.09440"/>
        <general ctrlrange="-2.09440 2.09440" forcerange="-176 176"/>
      </default>
      <default class="joint3_mid">
        <joint range="-2.96706 2.96706"/>
        <general ctrlrange="-2.96706 2.96706" forcerange="-110 110"/>
      </default>
      <default class="joint4_mid">
        <joint range="-2.09440 2.09440"/>
        <general ctrlrange="-2.09440 2.09440" forcerange="-110 110"/>
      </default>
      <default class="joint5_mid">
        <joint range="-2.96706 2.96706"/>
        <general ctrlrange="-2.96706 2.96706" forcerange="-110 110"/>
      </default>
      <default class="joint6_distal">
        <joint range="-2.09440 2.09440"/>
        <general ctrlrange="-2.09440 2.09440" forcerange="-40 40"/>
      </default>
      <default class="joint7_distal">
        <joint range="-3.05433 3.05433"/>
        <general ctrlrange="-3.05433 3.05433" forcerange="-40 40"/>
      </default>
    </default>
  </default>

  <asset>
    <mesh name="link_0" file="collision/link_0.stl"/>
    <mesh name="link_1" file="collision/link_1.stl"/>
    <mesh name="link_2" file="collision/link_2.stl"/>
    <mesh name="link_3" file="collision/link_3.stl"/>
    <mesh name="link_4" file="collision/link_4.stl"/>
    <mesh name="link_5" file="collision/link_5.stl"/>
    <mesh name="link_6" file="collision/link_6.stl"/>
    <mesh name="link_7" file="collision/link_7.stl"/>
  </asset>

  <worldbody>
    <body name="iiwa_link_0" childclass="iiwa">
      <geom type="mesh" contype="0" conaffinity="0" group="1" rgba="0.4 0.4 0.4 1" mesh="link_0"/>
      <geom type="mesh" rgba="0.4 0.4 0.4 1" mesh="link_0"/>

      <body name="iiwa_link_1" pos="0 0 0.15">
        <inertial pos="0 -0.03 0.12" quat="0.428904 0.562175 -0.562175 0.428904"
                  mass="3.4525" diaginertia="0.0218946 0.02183 0.00663837"/>
        <joint name="iiwa_joint_1" class="joint1"/>
        <geom pos="0 0 0.0075" type="mesh" contype="0" conaffinity="0" group="1" rgba="1 0.424 0.039 1" mesh="link_1"/>
        <geom pos="0 0 0.0075" type="mesh" rgba="1 0.424 0.039 1" mesh="link_1"/>

        <body name="iiwa_link_2" pos="0 0 0.19" quat="0 0 0.707107 0.707107">
          <inertial pos="0.0003 0.059 0.042" quat="0.701371 0.0898824 0.0898824 0.701371"
                    mass="3.4821" diaginertia="0.02179 0.0217049 0.00684512"/>
          <joint name="iiwa_joint_2" class="joint2"/>
          <geom type="mesh" contype="0" conaffinity="0" group="1" rgba="1 0.424 0.039 1" mesh="link_2"/>
          <geom type="mesh" rgba="1 0.424 0.039 1" mesh="link_2"/>

          <body name="iiwa_link_3" pos="0 0.21 0" quat="0 0 0.707107 0.707107">
            <inertial pos="0 0.03 0.13" quat="0.56292 0.427927 -0.427927 0.56292"
                      mass="4.05623" diaginertia="0.0321488 0.03204 0.00799117"/>
            <joint name="iiwa_joint_3" class="joint3_mid"/>
            <geom pos="0 0 -0.026" type="mesh" contype="0" conaffinity="0" group="1" rgba="1 0.424 0.039 1" mesh="link_3"/>
            <geom pos="0 0 -0.026" type="mesh" rgba="1 0.424 0.039 1" mesh="link_3"/>

            <body name="iiwa_link_4" pos="0 0 0.19" quat="0.707107 0.707107 0 0">
              <inertial pos="0 0.067 0.034" quat="0.991887 -0.127124 0 0"
                        mass="3.4822" diaginertia="0.02178 0.0216947 0.00684029"/>
              <joint name="iiwa_joint_4" class="joint4_mid"/>
              <geom type="mesh" contype="0" conaffinity="0" group="1" rgba="1 0.424 0.039 1" mesh="link_4"/>
              <geom type="mesh" rgba="1 0.424 0.039 1" mesh="link_4"/>

              <body name="iiwa_link_5" pos="0 0.21 0" quat="0 0 0.707107 0.707107">
                <inertial pos="0.0001 0.021 0.076" quat="0.365352 0.605407 -0.605407 0.365352"
                          mass="2.1633" diaginertia="0.0131987 0.01287 0.0036293"/>
                <joint name="iiwa_joint_5" class="joint5_mid"/>
                <geom pos="0 0 -0.026" type="mesh" contype="0" conaffinity="0" group="1" rgba="1 0.424 0.039 1" mesh="link_5"/>
                <geom pos="0 0 -0.026" type="mesh" rgba="1 0.424 0.039 1" mesh="link_5"/>

                <body name="iiwa_link_6" pos="0 0.0607 0.19" quat="0.707107 0.707107 0 0">
                  <inertial pos="0 0.0006 0.0004" quat="0.996112 0.088097 0 0"
                            mass="2.3466" diaginertia="0.006509 0.00631585 0.00447015"/>
                  <joint name="iiwa_joint_6" class="joint6_distal"/>
                  <geom type="mesh" contype="0" conaffinity="0" group="1" rgba="1 0.424 0.039 1" mesh="link_6"/>
                  <geom type="mesh" rgba="1 0.424 0.039 1" mesh="link_6"/>

                  <body name="iiwa_link_7" pos="0 0.081 0.0607" quat="0 0 0.707107 0.707107">
                    <inertial pos="0 0 0.02" quat="0.923068 0 0 0.384636"
                              mass="3.129" diaginertia="0.0152362 0.0140538 0.002872"/>
                    <joint name="iiwa_joint_7" class="joint7_distal"/>
                    <geom pos="0 0 -0.0005" type="mesh" contype="0" conaffinity="0" group="1" rgba="0.4 0.4 0.4 1" mesh="link_7"/>
                    <geom pos="0 0 -0.0005" type="mesh" rgba="0.4 0.4 0.4 1" mesh="link_7"/>
                    <site name="attachment_site" pos="0 0 0.05" size="0.005" rgba="1 0 0 1" group="4"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <contact>
    <exclude body1="iiwa_link_0" body2="iiwa_link_1"/>
    <exclude body1="iiwa_link_0" body2="iiwa_link_2"/>
    <exclude body1="iiwa_link_0" body2="iiwa_link_3"/>
    <exclude body1="iiwa_link_1" body2="iiwa_link_3"/>
    <exclude body1="iiwa_link_3" body2="iiwa_link_5"/>
    <exclude body1="iiwa_link_4" body2="iiwa_link_7"/>
    <exclude body1="iiwa_link_5" body2="iiwa_link_7"/>
  </contact>

  <actuator>
    <general name="actuator1" joint="iiwa_joint_1" class="joint1"/>
    <general name="actuator2" joint="iiwa_joint_2" class="joint2"/>
    <general name="actuator3" joint="iiwa_joint_3" class="joint3_mid"/>
    <general name="actuator4" joint="iiwa_joint_4" class="joint4_mid"/>
    <general name="actuator5" joint="iiwa_joint_5" class="joint5_mid"/>
    <general name="actuator6" joint="iiwa_joint_6" class="joint6_distal"/>
    <general name="actuator7" joint="iiwa_joint_7" class="joint7_distal"/>
  </actuator>

  <keyframe>
    <key name="home"  qpos="0 0 0 0 0 0 0"            ctrl="0 0 0 0 0 0 0"/>
    <key name="ready" qpos="0 0.5 0 -1.2 0 0.8 0"    ctrl="0 0.5 0 -1.2 0 0.8 0"/>
  </keyframe>
</mujoco>
