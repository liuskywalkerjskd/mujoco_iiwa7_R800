<mujoco model="iiwa7_obstacle_scene">
  <!-- Obstacle-avoidance scene: a vertical red pillar at (0.5, 0, mid-height).
       The demo precomputes an up-and-over waypoint path around it. -->

  <include file="../../iiwa7_mjcf/iiwa7_tuned.xml"/>

  <compiler meshdir="../../iiwa7_mjcf/meshes"/>
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="135" elevation="-20" offwidth="720" offheight="540"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="obstacle_mat" rgba="0.9 0.15 0.15 0.75"/>
    <material name="wp_mat" rgba="0.2 1.0 0.4 0.9"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.8" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Obstacle pillar: vertical cylinder at x=0.5, y=0, z from 0.25 to 0.70 -->
    <geom name="obstacle" type="cylinder" size="0.05 0.225"
          pos="0.5 0 0.475" material="obstacle_mat"
          contype="0" conaffinity="0"/>

    <!-- Start and goal markers -->
    <geom name="start_marker" type="sphere" size="0.02" pos="0.50 -0.28 0.55" material="wp_mat" contype="0" conaffinity="0"/>
    <geom name="goal_marker"  type="sphere" size="0.02" pos="0.50  0.28 0.55" material="wp_mat" contype="0" conaffinity="0"/>
  </worldbody>
</mujoco>
